# Copy to server/.env — never commit real values.

# Server-only Gemini key. Never put this in Vite or the browser.
GEMINI_API_KEY=

# Option A — paste the entire service account JSON as one line:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Option B — path to the downloaded .json file (easier for local dev):
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-adminsdk.json
FIREBASE_SERVICE_ACCOUNT_JSON=

PORT=8787
NODE_ENV=development

# Comma-separated allowed request origins, or * for local dev only.
# Production: your Firebase Hosting / custom domain(s) that serve the SPA.
# Capacitor / WebView: add capacitor://localhost and ionic://localhost (iOS) so the native app can call the API.
# Example:
# CORS_ORIGIN=https://regrade.web.app,https://regrade.firebaseapp.com,capacitor://localhost,ionic://localhost
CORS_ORIGIN=*

# Optional: comma-separated static API keys for POST /v1/feedback only (legacy cmdly endpoint).
# API_KEYS=
